{
    "name": "gilsegura/shared-bundle",
    "description": "Symfony integration for gilsegura/shared: Messenger-backed command/query buses, a Doctrine event store, DBAL types for the domain value objects, a criteria-to-Doctrine converter and the event-bus wiring.",
    "type": "symfony-bundle",
    "license": "MIT",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": "^8.4",
        "ext-json": "*",
        "doctrine/dbal": "^4.4",
        "doctrine/doctrine-bundle": "^3.2",
        "doctrine/orm": "^3.6",
        "doctrine/persistence": "^4.0",
        "gilsegura/serializer": "^1.0",
        "gilsegura/shared": "^1.0",
        "symfony/console": "^7.4 || ^8.1",
        "symfony/dependency-injection": "^7.4 || ^8.1",
        "symfony/event-dispatcher": "^7.4 || ^8.1",
        "symfony/http-kernel": "^7.4 || ^8.1",
        "symfony/messenger": "^7.4 || ^8.1"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpstan/phpstan-symfony": "^2.0",
        "phpunit/phpunit": "^13.1",
        "rector/rector": "^2.4",
        "symfony/phpunit-bridge": "^7.4 || ^8.1"
    },
    "autoload": {
        "psr-4": {
            "SharedBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SharedBundle\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
